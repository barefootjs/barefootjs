{
  "name": "data-table",
  "title": "Data Table",
  "category": "display",
  "description": "Data Table Helper Components Reusable sub-components for building sortable, filterable, paginated tables. Compose with the existing Table component for data display patterns.",
  "tags": [
    "multi-component"
  ],
  "stateful": false,
  "props": [
    {
      "name": "title",
      "type": "string",
      "required": true,
      "description": "Column title"
    },
    {
      "name": "sorted",
      "type": "SortDirection",
      "required": false,
      "description": "Current sort direction"
    },
    {
      "name": "onSort",
      "type": "() => void",
      "required": false,
      "description": "Callback when sort is toggled"
    }
  ],
  "subComponents": [
    {
      "name": "DataTablePagination",
      "description": "",
      "props": [
        {
          "name": "canPrev",
          "type": "boolean",
          "required": true,
          "description": "Whether previous page is available"
        },
        {
          "name": "canNext",
          "type": "boolean",
          "required": true,
          "description": "Whether next page is available"
        },
        {
          "name": "onPrev",
          "type": "() => void",
          "required": true,
          "description": "Callback for previous page"
        },
        {
          "name": "onNext",
          "type": "() => void",
          "required": true,
          "description": "Callback for next page"
        },
        {
          "name": "children",
          "type": "Child",
          "required": false,
          "description": "Page info label (rendered as children)"
        }
      ]
    }
  ],
  "examples": [
    {
      "title": "Sortable column header",
      "code": "<DataTableColumnHeader\n  title=\"Amount\"\n  sorted=\"asc\"\n  onSort={() => handleSort('amount')}\n/>"
    },
    {
      "title": "Pagination",
      "code": "<DataTablePagination\n  canPrev={page() > 0}\n  canNext={page() < pageCount() - 1}\n  onPrev={() => setPage(p => p - 1)}\n  onNext={() => setPage(p => p + 1)}\n>\n  Page {page() + 1} of {pageCount()}\n</DataTablePagination>"
    }
  ],
  "accessibility": {
    "ariaAttributes": [],
    "dataAttributes": [
      "data-slot"
    ]
  },
  "dependencies": {
    "internal": [
      "icon"
    ],
    "external": []
  },
  "related": [],
  "source": "ui/components/ui/data-table/index.tsx"
}
