{
  "name": "field",
  "title": "Field",
  "category": "display",
  "description": "Field Component A form field wrapper that provides structure for labels, descriptions, and error messages. Supports vertical and horizontal orientations. Based on shadcn/ui Field with native HTML + ARIA.",
  "tags": [
    "multi-component",
    "aria"
  ],
  "stateful": false,
